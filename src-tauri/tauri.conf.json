{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Melodii",
  "version": "1.0.0",
  "identifier": "com.melodii.app",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "beforeDevCommand": "npm --prefix ../frontend run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Melodii",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "app", "deb", "rpm", "appimage"],
    "resources": [
      "../backend/ffmpeg/**",
      "../backend/models/**"
    ],
    "externalBin": ["../backend/dist/melodii-backend"]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}

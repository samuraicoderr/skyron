# DJANGO STUFF ===================================================================
DJANGO_SETTINGS_MODULE=src.config.settings
DJANGO_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_1234567890abcdef
JWT_SIGNING_KEY=CHANGE_ME_IN_PRODUCTION_1234567890abcdef
DJANGO_DEBUG=False
RUNNING_ON_SERVER=False
SITE_NAME=melodii
ALLOWED_HOSTS=localhost,melodii-backend.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://melodii.com,https://www.melodii.com,https://melodii.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://melodii.com,https://www.melodii.com,https://melodii.vercel.app
CSP_SCRIPT_SRC=





# STRIPE STUFF ==================================================================
STRIPE_DEBUG=





# DATABASE STUFF =================================================================
USE_DEFAULT_BACKEND=True
ALT_BACKEND=postgres
DB_NAME=theapp_db
DB_USER=theapp_user
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION_1234567890
DB_HOST=postgres
DB_PORT=5432





# REDIS STUFF ===================================================================
REDIS_URL=redis://127.0.0.1:6379
FAIL_IF_REDIS_IS_NOT_AVAILABLE=True






# CLOUD STORAGE ================================================================
# Supported values: s3, r2, gcs, azure, b2, digitalocean, scaleway, oracle, ftp, sftp, dropbox, libcloud
# Leave empty for local filesystem storage (only works when DEBUG=True).
CLOUD_STORAGE_PROVIDER=s3
FORCE_CLOUD_STORAGE_ON_EXTERNAL_SERVICE=False

# ── Amazon S3 ────────────────────────────────
AWS_ACCESS_KEY_ID=rustfsadmin
AWS_SECRET_ACCESS_KEY=rustfsadmin
AWS_STORAGE_BUCKET_NAME=media
# AWS_S3_REGION_NAME=us-east-1
# AWS_DEFAULT_ACL=public-read
# AWS_QUERYSTRING_AUTH=False
AWS_S3_ENDPOINT_URL=http://127.0.0.1:9001
AWS_S3_ADDRESSING_STYLE=path
AWS_S3_CUSTOM_DOMAIN=

# ── Cloudflare R2 ────────────────────────────
# Also requires: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_STORAGE_BUCKET_NAME
R2_ACCOUNT_ID=

# ── DigitalOcean Spaces ──────────────────────
# Also requires: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_STORAGE_BUCKET_NAME
DO_SPACES_REGION=

# ── Backblaze B2 ─────────────────────────────
# Also requires: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_STORAGE_BUCKET_NAME
B2_S3_ENDPOINT=

# ── Scaleway Object Storage ──────────────────
# Also requires: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_STORAGE_BUCKET_NAME
SCALEWAY_REGION=

# ── Oracle Cloud Object Storage ──────────────
# Also requires: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_STORAGE_BUCKET_NAME
ORACLE_NAMESPACE=
ORACLE_REGION=

# ── Google Cloud Storage ─────────────────────
GS_BUCKET_NAME=
GS_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GS_DEFAULT_ACL=publicRead
GS_QUERYSTRING_AUTH=False

# ── Azure Blob Storage ───────────────────────
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=
AZURE_CONTAINER=
AZURE_CUSTOM_DOMAIN=

# ── Dropbox ──────────────────────────────────
DROPBOX_OAUTH2_TOKEN=
DROPBOX_ROOT_PATH=/media

# ── FTP ──────────────────────────────────────
# Format: ftp://user:password@host:port/path
FTP_STORAGE_LOCATION=

# ── SFTP ─────────────────────────────────────
SFTP_STORAGE_HOST=
SFTP_STORAGE_ROOT=/media
SFTP_STORAGE_USER=
SFTP_STORAGE_PASSWORD=
SFTP_STORAGE_PORT=22

# ── Apache Libcloud ──────────────────────────
LIBCLOUD_PROVIDER=
LIBCLOUD_KEY=
LIBCLOUD_SECRET=
LIBCLOUD_CONTAINER=






